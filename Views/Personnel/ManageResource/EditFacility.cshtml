@model ADNU_CFRS.Models.ViewModels.PersonnelVM
@{
    ViewBag.Title = "EditFacility";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-3">
    <div class="row justify-content-center">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0" style="margin-top: 10px">
                <div class="card-header text-primary d-flex justify-content-between align-items-center" id="card-table-hearder">
                    <label class="mb-0">
                        EDIT RESOURCE
                    </label>
                </div>
                <div class="card-body">
                    <div id="alert-section" class="alert d-none" role="alert">
                        Message
                    </div>

                    <div class="row">
                        <div class="col-md-12">
                            <p class="text-muted font-weight-bold border-bottom pb-1">
                                RESOURCE DETAILS
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-floating mb-3">
                                <input type="text" id="resource_id" class="form-control form-control-sm text-center" placeholder=" " autocomplete="off" value="@Model.resource.resource_id" readonly>
                                <label for="resource_id">Resource ID <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" id="resource_name" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.resource.resource_name">
                                <label for="resource_name">Resource Name <span class="text-danger">*</span></label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" id="resource_description" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.resource.resource_description">
                                <label for="resource_description">Description <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" id="resource_condition" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.resource.resource_condition">
                                <label for="resource_condition">Condition <span class="text-danger">*</span></label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <select id="resource_type" class="form-control form-control-sm">
                                    <option value="1">Facility</option>
                                </select>
                                <label>Resource Type <strong class="text-danger">*</strong></label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-2">
                            <div class="form-floating mb-3">
                                <select id="availability_status" class="form-control form-control-sm">
                                    <option value="1" @(Model.resource.availability_status == 1 ? "selected" : "")>Available</option>
                                    <option value="2" @(Model.resource.availability_status == 2 ? "selected" : "")>Unavailable</option>
                                </select>
                                <label>Status<strong class="text-danger">*</strong></label>
                            </div>
                        </div>
                    </div>

                    <br />
                    <div class="row">
                        <div class="col-md-12">
                            <p class="text-muted font-weight-bold border-bottom pb-1">
                                FACILITY DETAILS
                            </p>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" id="location" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.facility.location">
                                <label for="location">Location <span class="text-danger">*</span></label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input type="text" id="building" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.facility.building">
                                <label for="building">Building <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-floating mb-3">
                                <input type="number" id="floor_lvl" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.facility.floor_lvl">
                                <label for="floor_lvl">Floor Level <span class="text-danger">*</span></label>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-floating mb-3">
                                <input type="number" id="capacity" class="form-control form-control-sm" placeholder=" " autocomplete="off" value="@Model.facility.capacity">
                                <label for="capacity">Capacity <span class="text-danger">*</span></label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-gray-light d-flex justify-content-end">
                    <a href="@Url.Action("ManageResources", "Personnel")"
                       class="btn btn-default btn-sm mr-2"
                       title="Back"
                       onclick="ShowLoading()"
                       id="card-button-footer">
                        <i class="fa fa-arrow-left mr-1"></i> Back
                    </a>

                    <button type="submit"
                            class="btn btn-default btn-sm"
                            onclick="confirmSave()"
                            id="card-button-footer">
                        <i class="fa fa-save mr-1"></i> Save
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
    function confirmSave() {
        showConfirmation({
            title: "Update Facility",
            message: "Continue Saving?",
            subMessage: "",
            confirmText: "Yes, Save",
            confirmClass: "btn-success",
            icon: "fa-save",
            iconColor: "text-success",
            onConfirm: function () {
                SaveResource();
            }
        });
    }

    function SaveResource() {
        var resource_id = document.getElementById("resource_id").value;
        var resource_name = document.getElementById("resource_name").value;
        var resource_description = document.getElementById("resource_description").value;
        var resource_condition = document.getElementById("resource_condition").value;
        var resource_type = document.getElementById("resource_type").value;
        var availability_status = document.getElementById("availability_status").value;
        var location = document.getElementById("location").value;
        var building = document.getElementById("building").value;
        var floor_lvl = document.getElementById("floor_lvl").value;
        var capacity = document.getElementById("capacity").value;

        if (resource_name === "" || resource_description === "" || resource_condition === "" || resource_type === "" || availability_status === "" ||
            location === "" || building === "" || floor_lvl === "" || capacity === "") {
            showAlert("Please fill in all required fields.", "danger");
            return false;
        }
        else {
            var url = '@Url.Action("UpdateFacility", "Personnel")';
            var formData = new FormData();
            formData.append("resource_id", resource_id);
            formData.append("resource_name", resource_name);
            formData.append("resource_description", resource_description);
            formData.append("resource_condition", resource_condition);
            formData.append("resource_type", resource_type);
            formData.append("availability_status", availability_status);
            formData.append("location", location);
            formData.append("building", building);
            formData.append("floor_lvl", floor_lvl);
            formData.append("capacity", capacity);

            $.ajax({
                type: "POST",
                url: url,
                data: formData,
                processData: false,
                contentType: false,
                enctype: 'multipart/form-data',
                success: function (response) {
                    showAlert(response.msg, response.result);

                    if (response.result == "success") {
                            setTimeout(function () {
                            window.location = '@Url.Action("ManageResources", "Personnel")';
                        }, 3000)
                    }
                },
                error: function (xhr, status, error) {
                    showAlert("Something went wrong. Please try again.", "error");
                    console.error(xhr.responseText);
                }
            });
        }
    }
</script>


